<!DOCTYPE html>

<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LP Print — พิมพ์งานคัสต้อมกระดาษทุกรูปแบบ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Mali:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
<style>
:root {
  --peach: #FFDDD4;
  --cream: #FFF6EE;
  --mocha: #A08682;
  --mocha-dark: #6B5651;
  --pink: #FFB8B8;
  --pink-deep: #FF8FA3;
  --mint: #C8E7D8;
  --lemon: #FFF0B3;
  --ink: #4A3A37;
  --line: #E8D5CD;
  --shadow: 0 3px 0 #C9A99F;
  --green: #5BA67D;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--cream); color: var(--ink);
  font-family: 'Mali', cursive; font-size: 16px;
  line-height: 1.6; -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ── background blobs ── */
body::before {
content: ‘’; position: fixed; inset: 0; pointer-events: none; z-index: -1;
background-image:
radial-gradient(circle at 8% 15%, var(–peach) 0%, transparent 38%),
radial-gradient(circle at 92% 65%, var(–mint) 0%, transparent 38%),
radial-gradient(circle at 48% 92%, var(–lemon) 0%, transparent 32%);
opacity: .45;
}

/* ── navbar ── */
header {
padding: 14px 32px; display: flex; justify-content: space-between; align-items: center;
position: sticky; top: 0; z-index: 200;
background: rgba(255,246,238,.88); backdrop-filter: blur(12px);
border-bottom: 2px dashed var(–peach);
}
.brand {
font-weight: 700; font-size: 22px; color: var(–mocha-dark);
text-decoration: none; letter-spacing: -.02em;
}
.brand span { color: var(–pink-deep); }
nav { display: flex; gap: 4px; align-items: center; }
.nav-link {
padding: 7px 18px; border-radius: 20px; font-size: 14px; font-weight: 600;
color: var(–mocha-dark); text-decoration: none; transition: all .15s;
border: 2px solid transparent; font-family: ‘Mali’, cursive;
}
.nav-link:hover { background: var(–peach); border-color: var(–line); }
.nav-link.active { background: var(–pink-deep); color: white; border-color: var(–pink-deep); }
.nav-order {
padding: 7px 20px; border-radius: 20px; font-size: 14px; font-weight: 700;
color: white; text-decoration: none; background: var(–mocha-dark);
border: 2px solid var(–mocha-dark); font-family: ‘Mali’, cursive;
box-shadow: var(–shadow); transition: all .15s;
}
.nav-order:hover { transform: translateY(2px); box-shadow: 0 1px 0 #C9A99F; }
.hamburger {
display: none; background: var(–peach); border: 2px solid var(–line);
border-radius: 12px; padding: 6px 12px; font-size: 18px; cursor: pointer;
color: var(–mocha-dark); font-family: inherit;
}
.mobile-nav {
display: none; flex-direction: column; gap: 6px; padding: 14px 24px 18px;
background: rgba(255,246,238,.96); border-bottom: 2px dashed var(–peach);
position: sticky; top: 57px; z-index: 199;
}
.mobile-nav.open { display: flex; }
.mobile-nav .nav-link { text-align: center; }
@media (max-width: 640px) { nav { display: none; } .hamburger { display: block; } }

/* ── layout ── */
main { max-width: 1040px; margin: 0 auto; padding: 0 24px 100px; }

/* ── hero ── */
.hero {
padding: 72px 0 56px;
display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; align-items: center;
}
@media (max-width: 760px) { .hero { grid-template-columns: 1fr; padding: 40px 0 32px; gap: 32px; } }

.hero-eyebrow {
display: inline-flex; align-items: center; gap: 8px;
padding: 5px 16px; border-radius: 20px;
background: var(–peach); border: 2px solid var(–line);
font-size: 12px; font-weight: 700; color: var(–mocha-dark);
text-transform: uppercase; letter-spacing: .1em; margin-bottom: 18px;
}
.hero-eyebrow::before { content: ‘✦’; color: var(–pink-deep); font-size: 10px; }

.hero-title {
font-size: clamp(34px, 5.5vw, 56px); font-weight: 700;
color: var(–mocha-dark); line-height: 1.15; margin-bottom: 18px;
letter-spacing: -.02em;
}
.hero-title em { font-style: normal; color: var(–pink-deep); }

.hero-desc { font-size: 15px; color: var(–mocha); line-height: 1.85; margin-bottom: 32px; max-width: 480px; }

.hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }
.btn-primary {
display: inline-flex; align-items: center; gap: 8px;
padding: 13px 26px; background: var(–pink-deep); color: white;
border-radius: 18px; font-family: ‘Mali’, cursive; font-size: 15px; font-weight: 700;
text-decoration: none; box-shadow: var(–shadow); transition: all .15s; border: none; cursor: pointer;
}
.btn-primary:hover { transform: translateY(2px); box-shadow: 0 1px 0 #C9A99F; }
.btn-secondary {
display: inline-flex; align-items: center; gap: 8px;
padding: 13px 26px; background: white; color: var(–mocha-dark);
border-radius: 18px; font-family: ‘Mali’, cursive; font-size: 15px; font-weight: 700;
text-decoration: none; border: 2px solid var(–line); box-shadow: var(–shadow); transition: all .15s;
}
.btn-secondary:hover { background: var(–peach); border-color: var(–mocha); }

/* hero card */
.hero-card {
background: white; border: 2px solid var(–line); border-radius: 28px;
padding: 28px; box-shadow: var(–shadow); position: relative; overflow: hidden;
animation: float 5s ease-in-out infinite;
}
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
.hero-card::after {
content: ‘’; position: absolute; top: -50px; right: -50px;
width: 180px; height: 180px; border-radius: 50%;
background: var(–peach); opacity: .4; pointer-events: none;
}
.hero-card-label {
font-size: 11px; font-weight: 700; color: var(–mocha); text-transform: uppercase;
letter-spacing: .1em; margin-bottom: 18px;
}
.stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 18px; }
.stat {
background: var(–cream); border: 2px solid var(–line); border-radius: 16px;
padding: 14px; transition: all .15s;
}
.stat:hover { background: var(–peach); border-color: var(–mocha); }
.stat-val { font-size: 22px; font-weight: 700; color: var(–mocha-dark); line-height: 1.1; margin-bottom: 3px; }
.stat-val small { font-size: 13px; color: var(–pink-deep); font-weight: 600; }
.stat-lbl { font-size: 11px; color: var(–mocha); font-weight: 500; line-height: 1.4; }
.tag-row { display: flex; flex-wrap: wrap; gap: 6px; }
.tag {
padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600;
background: var(–mint); color: #2E6649; border: 1.5px solid #A8D4BB;
}

/* ── divider ── */
.divider { border: none; border-top: 2px dashed var(–line); margin: 0; }

/* ── section wrapper ── */
.section { padding: 60px 0 0; }
.sec-eyebrow {
display: inline-flex; align-items: center; gap: 6px;
padding: 4px 14px; border-radius: 20px; font-size: 11px; font-weight: 700;
text-transform: uppercase; letter-spacing: .1em;
background: var(–peach); color: var(–mocha-dark); border: 2px solid var(–line);
margin-bottom: 10px;
}
.sec-title { font-size: clamp(24px,3.5vw,36px); font-weight: 700; color: var(–mocha-dark); margin-bottom: 8px; }
.sec-desc { color: var(–mocha); font-size: 15px; max-width: 560px; margin-bottom: 36px; line-height: 1.75; }

/* ── about grid ── */
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
@media (max-width: 760px) { .about-grid { grid-template-columns: 1fr; } }

.about-main {
grid-column: 1 / -1; background: white; border: 2px solid var(–line);
border-radius: 24px; padding: 32px; box-shadow: var(–shadow);
display: grid; grid-template-columns: 1.2fr 1fr; gap: 32px; align-items: start;
}
@media (max-width: 760px) { .about-main { grid-template-columns: 1fr; grid-column: auto; } }
.about-main-title { font-size: 20px; font-weight: 700; color: var(–mocha-dark); margin-bottom: 12px; }
.about-main-body { font-size: 14px; color: var(–mocha); line-height: 1.85; }
.about-main-body p + p { margin-top: 10px; }
.about-highlight { background: var(–peach); border-radius: 18px; padding: 22px; border: 2px solid var(–line); }
.about-hl-title { font-size: 11px; font-weight: 700; color: var(–mocha); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 14px; }
.about-hl-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.about-hl-list li { font-size: 14px; color: var(–mocha-dark); display: flex; gap: 10px; font-weight: 500; align-items: flex-start; }
.about-hl-list li::before { content: ‘—’; color: var(–pink-deep); flex-shrink: 0; margin-top: 1px; }

.about-card {
background: white; border: 2px solid var(–line); border-radius: 22px;
padding: 26px; box-shadow: var(–shadow); transition: all .2s;
}
.about-card:hover { transform: translateY(-3px); box-shadow: 0 6px 0 #C9A99F; }
.about-card.dark { background: var(–mocha-dark); border-color: var(–mocha-dark); }
.about-card.dark .about-card-title { color: var(–peach); }
.about-card.dark .about-card-text { color: rgba(255,246,238,.7); }
.about-icon {
width: 42px; height: 42px; border-radius: 13px; background: var(–peach);
border: 2px solid var(–line); display: flex; align-items: center;
justify-content: center; font-size: 17px; margin-bottom: 14px;
}
.about-card.dark .about-icon { background: rgba(255,221,212,.12); border-color: rgba(255,221,212,.25); }
.about-card-title { font-size: 16px; font-weight: 700; color: var(–mocha-dark); margin-bottom: 6px; }
.about-card-text { font-size: 13px; color: var(–mocha); line-height: 1.7; }

/* ── steps ── */
.steps {
display: grid; grid-template-columns: repeat(4,1fr);
background: white; border: 2px solid var(–line); border-radius: 24px;
overflow: hidden; box-shadow: var(–shadow);
}
@media (max-width: 760px) { .steps { grid-template-columns: 1fr 1fr; } }
@media (max-width: 480px) { .steps { grid-template-columns: 1fr; } }
.step { padding: 28px 22px; border-right: 2px solid var(–line); position: relative; }
.step:last-child { border-right: none; }
@media (max-width: 760px) {
.step:nth-child(2) { border-right: none; }
.step:nth-child(3) { border-right: 2px solid var(–line); }
.step:nth-child(1),.step:nth-child(2) { border-bottom: 2px solid var(–line); }
}
@media (max-width: 480px) { .step { border-right: none; border-bottom: 2px solid var(–line); } .step:last-child { border-bottom: none; } }
.step-num {
width: 34px; height: 34px; border-radius: 11px; display: flex; align-items: center;
justify-content: center; font-size: 14px; font-weight: 700; margin-bottom: 14px;
border: 2px solid;
}
.step:nth-child(1) .step-num { background: var(–pink-deep); color: white; border-color: var(–pink-deep); }
.step:nth-child(2) .step-num { background: var(–lemon); color: #7A6300; border-color: #E8D000; }
.step:nth-child(3) .step-num { background: var(–mint); color: #2E6649; border-color: #A8D4BB; }
.step:nth-child(4) .step-num { background: var(–peach); color: var(–mocha-dark); border-color: var(–mocha); }
.step-title { font-size: 15px; font-weight: 700; color: var(–mocha-dark); margin-bottom: 6px; }
.step-desc { font-size: 13px; color: var(–mocha); line-height: 1.65; }
.step-arrow {
position: absolute; top: 28px; right: -9px;
width: 16px; height: 16px; background: white;
border-right: 2px solid var(–line); border-top: 2px solid var(–line);
transform: rotate(45deg); z-index: 1;
}
@media (max-width: 760px) { .step-arrow { display: none; } }

/* ── CTA banner ── */
.cta-banner {
margin-top: 28px; background: var(–mocha-dark); border-radius: 22px;
padding: 28px 32px; display: flex; justify-content: space-between;
align-items: center; gap: 20px; flex-wrap: wrap; box-shadow: var(–shadow);
}
.cta-banner h3 { font-size: 20px; font-weight: 700; color: var(–peach); margin-bottom: 4px; }
.cta-banner p { font-size: 14px; color: rgba(255,221,212,.7); }
.btn-cta {
display: inline-flex; align-items: center; padding: 12px 26px;
background: var(–pink-deep); color: white; border-radius: 16px;
font-family: ‘Mali’, cursive; font-size: 15px; font-weight: 700;
text-decoration: none; box-shadow: 0 3px 0 rgba(0,0,0,.25); transition: all .15s;
white-space: nowrap;
}
.btn-cta:hover { transform: translateY(2px); box-shadow: 0 1px 0 rgba(0,0,0,.2); }

/* ── LINE strip ── */
.line-strip {
margin-top: 16px; background: white; border: 2px solid var(–line);
border-radius: 18px; padding: 20px 28px;
display: flex; justify-content: space-between; align-items: center;
gap: 16px; flex-wrap: wrap; box-shadow: var(–shadow);
}
.line-strip h4 { font-size: 16px; font-weight: 700; color: var(–mocha-dark); }
.line-strip p { font-size: 13px; color: var(–mocha); }

/* ── footer ── */
footer {
padding: 40px 24px; text-align: center;
font-size: 13px; color: var(–mocha); border-top: 2px dashed var(–line);
margin-top: 60px;
}
footer a { color: var(–mocha-dark); font-weight: 600; text-decoration: none; }
footer a:hover { color: var(–pink-deep); }

/* ── animations ── */
.fade-up {
opacity: 0; transform: translateY(24px);
transition: opacity .5s ease, transform .5s ease;
}
.fade-up.visible { opacity: 1; transform: translateY(0); }
</style>

</head>
